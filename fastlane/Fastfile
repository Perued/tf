default_platform(:ios)

platform :ios do
  desc "Build and upload the app to TestFlight (manual cert/profile)"
  lane :beta do
    api_key = app_store_connect_api_key(
      keyfile: "AuthKey.json",
      in_house: false
    )

    UI.message("Assuming signing certificate and provisioning profile are already installed on the runner")

    app_identifier = ENV.fetch("APP_IDENTIFIER", "com.qixin.iphonexx")
    scheme = ENV.fetch("SCHEME", "App")
    workspace = ENV["WORKSPACE"]
    profile_name = ENV.fetch("PROVISIONING_PROFILE_NAME", "")

    export_options = {
      provisioningProfiles: {
        app_identifier => profile_name
      }
    }

    build_params = {
      scheme: scheme,
      export_method: "app-store",
      export_options: export_options
    }
    build_params[:workspace] = workspace if workspace

    build_app(build_params)

    upload_to_testflight(api_key: api_key, skip_waiting_for_build_processing: false)
  end

  desc "Upload an existing IPA to TestFlight"
  lane :upload_ipa do
    api_key = app_store_connect_api_key(
      keyfile: "AuthKey.json",
      in_house: false
    )

    ipa_path = ENV.fetch("IPA_PATH", "app.ipa")
    UI.user_error!("IPA file not found: #{ipa_path}") unless File.exist?(ipa_path)

    upload_to_testflight(
      ipa: ipa_path,
      api_key: api_key,
      skip_waiting_for_build_processing: false
    )
  end
end
